# EditorConfig for ktlint and IDE consistency
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
ktlint_code_style = android_studio

[*.{kt,kts}]
max_line_length = 120
indent_size = 4
ij_kotlin_allow_trailing_comma = true
ij_kotlin_allow_trailing_comma_on_call_site = true
ktlint_standard_trailing-comma-on-call-site = enabled
ktlint_standard_trailing-comma-on-declaration-site = enabled
ktlint_function_naming_ignore_when_annotated_with = Composable,Suppress
ktlint_constructor = enabled

[*.gradle]
max_line_length = 120
indent_size = 4

[*.xml]
indent_size = 2

[*.json]
indent_size = 2

[*.md]
max_line_length = off
trim_trailing_whitespace = false

# Generated code (SQLDelight, KSP, etc.) does not need to comply with ktlint rules.
[{**/build/generated/**/*.kt,**/build/generated/**/*.kts}]
ktlint_standard_package-name = disabled
max_line_length = off
