# Built application files
*.apk
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/
release/

# Gradle files
.gradle/
.gradle-home/
.kotlin/
build/

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ
*.iml
.idea/
misc.xml
deploymentTargetDropDown.xml
render.experimental.xml

# Keystore files (NEVER commit these!)
*.jks
*.keystore
keystore.properties
keystore/

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild
.cxx/

# Version control
vcs.xml

# lint
lint/intermediates/
lint/generated/
lint/outputs/
lint/tmp/
lint-results.html
lint-results.xml

# macOS
.DS_Store

# Windows
Thumbs.db

# Backup files
*~
*.swp
*.bak

